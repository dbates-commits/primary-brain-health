{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [".env", "tsconfig.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "public/admin/**"],
      "env": [
        "TINA_TOKEN",
        "NEXT_PUBLIC_TINA_CLIENT_ID",
        "TINA_PUBLIC_IS_LOCAL",
        "GITHUB_BRANCH",
        "VERCEL_GIT_COMMIT_REF",
        "HEAD"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
