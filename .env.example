# Tina CMS — get these from tina.io for your project
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Production site URL — used by Next.js metadata for absolute OG/canonical URLs.
# Falls back to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=https://primarybrainhealth.com

# HubSpot Forms API — both /api/intake and /api/contact submit to HubSpot,
# which creates the contact and fires the workflow tied to each form.
# Find these in the HubSpot form's URL or its embed code.
HUBSPOT_PORTAL_ID=
HUBSPOT_INTAKE_FORM_GUID=
HUBSPOT_CONTACT_FORM_GUID=