# Tina CMS — get these from tina.io for your project
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Production site URL — used by Next.js metadata for absolute OG/canonical URLs.
# Falls back to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=https://primarybrainhealth.com

# Resend — transactional email for the intake + contact forms.
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender on your Resend domain. Format: "Name <addr@yourdomain.com>".
RESEND_FROM_ADDRESS=Primary Brain Health <noreply@primarybrainhealth.com>

# Where consultation intake submissions go (homepage form, /api/intake).
INTAKE_TO_ADDRESS=intake@primarybrainhealth.com

# Where contact form submissions go (contact page, /api/contact).
CONTACT_TO_ADDRESS=hello@primarybrainhealth.com
