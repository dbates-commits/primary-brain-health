# Tina CMS — get these from tina.io for your project
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Production site URL — used by Next.js metadata for absolute OG/canonical URLs.
# Falls back to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=https://primarybrainhealth.com

# HubSpot Forms API — both /api/intake and /api/contact submit to HubSpot,
# which creates the contact and fires the workflow tied to each form.
# Find these in the HubSpot form's URL or its embed code.
HUBSPOT_PORTAL_ID=
HUBSPOT_INTAKE_FORM_GUID=
HUBSPOT_CONTACT_FORM_GUID=

# Linear sync for the beads issue tracker (`bd linear sync`). See docs/beads-linear-sync.md.
# IMPORTANT: provide these as environment variables only — never `bd config set linear.api_key`,
# which writes the key into the Dolt config and publishes it to the beads-backup branch.
# Put the real values in a gitignored .env (this file holds names only, never real values).
# API key: Linear → Settings → Security & access → Personal API keys.
# Team UUID: run `bd linear teams` after exporting LINEAR_API_KEY.
LINEAR_API_KEY=
LINEAR_TEAM_ID=