# Neon Postgres connection string for the funnel app.
#
# Local dev:  copy this file to .env.local and paste your Neon dev-branch
#             connection string (Neon console → Connect, or the
#             get_connection_string MCP tool).
# Vercel:     provided automatically per environment by the Neon integration —
#             do not set it manually there.
#
# Use the pooled ("-pooler") host for serverless request handlers.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- Linus Health Public API (sandbox defaults) ---
#
# Local dev:  copy to .env.local and fill in the sandbox client credentials
#             (sent by the Linus integration team in a one-time share).
# Vercel:     set per environment — Preview/dev → sandbox (the URLs below),
#             Production → the prod URLs/audience.
LINUS_CLIENT_ID=""
LINUS_CLIENT_SECRET=""
LINUS_BASE_URL="https://dtc.us.stgint.linushealth.cloud/v1"
LINUS_TOKEN_URL="https://login.staging-integration.linus.health/oauth/token"
LINUS_AUDIENCE="https://stgint-linus-us.us.auth0.com/api/v2/"
# Campaigns now live in code: src/lib/linus/campaigns.ts (sandbox vs prod lists
# selected by VERCEL_ENV). No env var to set.

# --- Stripe (webhook / fulfillment only) ---
#
# This app no longer renders checkout — booking and payment live in the
# marketing app. It still needs Stripe credentials because it hosts the ONLY
# webhook endpoint, and fulfillment calls the API: `paymentIntents.retrieve`
# to re-fetch the charge, and the catalog price to validate the amount.
#
# ⚠️ Use the SAME Stripe account AND the same STRIPE_ASSESSMENT_PRICE_ID as
# apps/marketing. Fulfillment rejects any payment whose amount/currency doesn't
# match the catalog price (see recordSucceededPayment in @pbh/booking/server),
# so a mismatch between the two apps silently fails every payment after the
# customer has already been charged.
#
# Local dev:  copy to .env.local and paste your Stripe TEST keys (Dashboard →
#             Developers → API keys). Demo test card: 4242 4242 4242 4242.
# Vercel:     set per environment — Preview/dev → test keys, Production → live.
#
# A restricted key (`rk_…`) works, provided it can read prices and payment
# intents. The secret key is server-only — never expose it.
STRIPE_SECRET_KEY="sk_test_..."
# Unused by this app today (no client-side checkout here). Kept so the funnel
# can mount a Stripe UI again without re-plumbing config.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Catalog Price ID for the assessment. The amount, currency, and product name
# come from the Stripe Price/Product (the source of truth) — there is no
# hardcoded price in the code anymore. This app reads it to validate that a
# webhook's payment matches what should have been charged.
#
# The price must be ACTIVE: an archived price throws before checkout can even
# start ("Stripe price … is not active", see getAssessmentCatalogEntry), and
# Stripe rejects it at session creation independently.
#
# Local dev:  a test-mode Price ID from the SAME account as your secret key
#             above, and identical to apps/marketing's (Dashboard → Product
#             catalog, or `stripe prices create`).
# Vercel:     set per environment — Preview/dev → sandbox price, Production →
#             the live `clinical_assessment` price.
STRIPE_ASSESSMENT_PRICE_ID="price_..."

# Price ID for the Comprehensive ($449) package. Same account as above.
# Optional today: the Comprehensive card is not purchasable (its clinical
# fulfillment is undefined), so nothing reads this until that lands — but
# checkout throws the moment it does, so set it before enabling that CTA.
STRIPE_COMPREHENSIVE_PRICE_ID="price_..."

# Webhook signing secret — verifies inbound events at /api/stripe/webhook.
# Local dev:  run `stripe listen --forward-to localhost:3001/api/stripe/webhook`
#             and paste the printed `whsec_…` here.
# Vercel:     each hosted endpoint has its own signing secret (Dashboard →
#             Developers → Webhooks → your endpoint). Set it per environment.
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Transactional email (Resend + @pbh/emails) ---
#
# ALL optional: with RESEND_API_KEY unset, every send is a logged no-op and the
# funnel works normally — no email setup needed for local dev.
#
# Local dev:  a free personal Resend account can send from the default
#             onboarding@resend.dev to its own account email, no domain
#             verification needed.
# Vercel:     set per environment once the PBH Resend account exists — separate
#             dev/prod API keys, and EMAIL_FROM on the verified domain.
RESEND_API_KEY=""
# Sender identity; requires a Resend-verified domain in production.
# Default when unset: "Primary Brain Health <onboarding@resend.dev>"
EMAIL_FROM=""
# Absolute base for links inside emails (login, assessments).
# Default when unset: http://localhost:3001
APP_BASE_URL=""
# Absolute URL of the email header logo. Default when unset:
# {APP_BASE_URL}/email-assets/pbh-logo.png (served from this app's public/).
# Point it at a stable production/CDN URL before launch.
EMAIL_LOGO_URL=""
# The /emails template preview page is visible on dev/preview deployments and
# hidden in production; set to "1" to expose it in production too.
EMAIL_PREVIEW_ENABLED=""

# --- Auth.js (NextAuth) — passwordless magic-link sign-in ---
#
# Secret used to encrypt session/verification tokens. REQUIRED in production.
# Local dev:  copy to .env.local and generate one with `npx auth secret` (or
#             `openssl rand -base64 32`).
# Vercel:     set per environment (a distinct value for prod vs preview).
AUTH_SECRET=""
# Canonical origin Auth.js builds callback/magic-link URLs against. On Vercel it
# is inferred automatically; set it only for local dev if the default
# (http://localhost:3001) is wrong, or for non-Vercel hosts.
# AUTH_URL="http://localhost:3001"
#
# Magic-link emails send through the SAME Resend config as the transactional
# emails above (RESEND_API_KEY / EMAIL_FROM). With RESEND_API_KEY unset, the
# magic-link email is a logged no-op AND the dev sign-in URL is printed to the
# server console so you can still complete sign-in locally.

# --- Booking email confirmation ---
#
# Signup is gated on confirming the email address: we mail a one-time link that
# stamps `users.email_verified` and resumes the booking at the right step.

# Absolute base for the confirmation link. Must point at the MARKETING app —
# that is where the booking modal lives, so a link aimed at the funnel would
# land on a page with no flow to resume.
# Default when unset: http://localhost:3000
BOOKING_BASE_URL=""

# Signs the short-lived, httpOnly `pbh_booking_resume` cookie that proves this
# browser confirmed an address. REQUIRED wherever the booking flow runs.
# Local dev:  generate one with `openssl rand -base64 32`.
# Vercel:     set per environment (a distinct value for prod vs preview).
BOOKING_RESUME_SECRET=""
