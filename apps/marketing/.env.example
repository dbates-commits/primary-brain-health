# Marketing app environment.
#
# The booking modal on the home page runs the real end-to-end flow (account →
# consent → Stripe Embedded Checkout → Linus enrollment), so the marketing app
# now needs the same DB / Stripe / Linus config as the funnel. Copy this file to
# .env.local for local dev; on Vercel these are set per environment.

# --- Neon Postgres (shared with the funnel) ---
# Use the pooled ("-pooler") host for serverless request handlers.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- Linus Health Public API (sandbox defaults) ---
# Preview/dev → sandbox (the URLs below); Production → the prod URLs/audience.
LINUS_CLIENT_ID=""
LINUS_CLIENT_SECRET=""
LINUS_BASE_URL="https://dtc.us.stgint.linushealth.cloud/v1"
LINUS_TOKEN_URL="https://login.staging-integration.linus.health/oauth/token"
LINUS_AUDIENCE="https://stgint-linus-us.us.auth0.com/api/v2/"

# --- Stripe (Embedded Checkout) ---
# Local dev: TEST keys (Dashboard → Developers → API keys). Test card 4242…4242.
# The secret key is server-only; the publishable key is safe in the browser.
#
# No STRIPE_WEBHOOK_SECRET here: the webhook is the funnel's, not ours. Booking
# starts in this app, but Stripe endpoints are account-scoped, so the funnel's
# single endpoint receives every event and is the sole fulfillment backstop.
#
# ⚠️ Because of that split, this app and apps/funnel must point at the SAME
# Stripe account and the SAME STRIPE_ASSESSMENT_PRICE_ID. We charge here; the
# funnel re-fetches the PaymentIntent and checks it against the catalog price.
# On a mismatch it can't see the charge (wrong account) or rejects it as
# "amount/currency mismatch" — after the customer has already paid.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Catalog Price ID charged at checkout. The amount, currency, and product name
# come from the Stripe Price/Product (the source of truth) — no hardcoded price
# in the code. Use a test-mode Price ID from the SAME account as the keys above
# — and the same one apps/funnel is configured with (Dashboard → Product
# catalog, or `stripe prices create`). On Vercel, set per environment: sandbox
# price on Preview, the live price in Production.
#
# The price must be ACTIVE. Archiving it breaks checkout outright: the catalog
# lookup throws, and Stripe refuses an inactive price on the session anyway.
STRIPE_ASSESSMENT_PRICE_ID="price_..."

# Price ID for the Comprehensive ($449) package. Same account as above.
# Optional today: the Comprehensive card is not purchasable (its clinical
# fulfillment is undefined), so nothing reads this until that lands — but
# checkout throws the moment it does, so set it before enabling that CTA.
STRIPE_COMPREHENSIVE_PRICE_ID="price_..."

# Keyed hash of client IPs stored on consent/audit rows. Set the SAME value in
# every app so a given IP hashes identically across the funnel and marketing.
IP_HASH_SECRET=""

# Base URL of the funnel app, used by the booking confirmation step to hand the
# paid + enrolled user off to the funnel's /login → /assessments.
# Local dev: http://localhost:3001
NEXT_PUBLIC_FUNNEL_URL="http://localhost:3001"

# --- Booking email confirmation ---
#
# Signup is gated on confirming the email address: we mail a one-time link that
# stamps `users.email_verified` and resumes the booking at the right step.

# Absolute base for the confirmation link. Must point at the MARKETING app —
# that is where the booking modal lives, so a link aimed at the funnel would
# land on a page with no flow to resume.
# Local dev:  leave unset (defaults to http://localhost:3000).
# Vercel:     leave unset on Preview — it falls back to VERCEL_URL, the
#             per-deployment host, so every preview links to itself. Set it
#             explicitly in Production, where VERCEL_URL is the generated
#             *.vercel.app host rather than the real domain.
BOOKING_BASE_URL=""

# Signs the short-lived, httpOnly `pbh_booking_resume` cookie that proves this
# browser confirmed an address. REQUIRED wherever the booking flow runs.
# Local dev:  generate one with `openssl rand -base64 32`.
# Vercel:     set per environment (a distinct value for prod vs preview).
BOOKING_RESUME_SECRET=""

# Shared secret for the post-payment sign-in handoff. Marketing mints a
# short-lived, single-use token after a verified payment; the funnel exchanges it
# for a real session so the customer lands on /assessments already signed in.
# MUST be the SAME value in both apps — one signs, the other verifies.
# Local dev:  generate with `openssl rand -base64 32` and paste into BOTH
#             apps/funnel/.env.local and apps/marketing/.env.local.
# Vercel:     set the same value on both projects, per environment.
AUTH_HANDOFF_SECRET=""
