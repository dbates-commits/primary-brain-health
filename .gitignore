# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# turborepo
.turbo

# react-email preview server (generated by `email dev`)
.react-email/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static

# private docs (proposals, pricing, estimates, SOW scope) — kept locally, never shared
# everything internal lives under docs/_private/ (incl. docs/_private/phase-2/)
docs/_private/

# SOW proposal contains pricing — keep local, never tracked
docs/sow2/proposal/SOW2-Proposal.md

# local editor/harness config (machine-specific paths)
.claude/settings.json
.gstack/

# Dolt database files (added by bd init)
.dolt/
*.db
